# App
APP_ENV=development
SECRET_KEY=change-me-to-at-least-32-characters-long
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql://synthrare:synthrare_dev@postgres:5432/synthrare
DATABASE_POOL_SIZE=10

# Queue
REDIS_URL=redis://localhost:6379/0

# DO Spaces
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=synthrare-datasets
DO_SPACES_CDN_ENDPOINT=

# DO Gradient Inference
DO_GRADIENT_API_KEY=
DO_GRADIENT_INFERENCE_ENDPOINT=

# HuggingFace
HF_TOKEN=
HF_MODEL_REPO_FINANCE=synthrare/finance-ctgan
HF_MODEL_REPO_AVIATION=synthrare/aviation-timegan
HF_MODEL_REPO_HEALTHCARE=synthrare/healthcare-ctgan

# Dev overrides
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=./data/uploads

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
